# Database
# Local dev: persistent Postgres on :55434 (started by `make db-up-dev`).
# This is separate from the :55433 test DB which is wiped by `make db-down-test`.
# Production: connection string from RDS/Neon/Cloud SQL with DB_SSL=true.
DATABASE_URL=postgresql://opengithub:opengithub@localhost:55434/opengithub_dev
DB_SSL=false
DB_PASSWORD=opengithub

# Cloud provider region (AWS, GCP, Azure)
AWS_REGION=us-east-1

# OpenAI -- powers ai-001 (AI repo summary, PR summary tab, AI changelog).
# Same provider already used by the Codex build loop. Get a key at
# https://platform.openai.com/api-keys. Use a project-scoped key with usage
# limits set; the runtime caps per-user calls via api-003 rate buckets.
OPENAI_API_KEY=sk-proj-your-key-here

# Cloudflare -- CDN and edge caching (optional, only if clone needs edge layer)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Auth -- Rust-native session signing (tower-sessions)
# Set APP_ENV=staging or APP_ENV=production in deployed ECS tasks to enable fail-fast validation.
# In staging/production: APP_URL, PUBLIC_APP_URL, and API_URL must be HTTPS; SESSION_COOKIE_SECURE must be true.
# See docs/production-runtime-env.md for the full API/web/worker contract.
APP_ENV=development
PORT=3016
SESSION_SECRET=generate-with-openssl-rand-base64-32
APP_URL=http://localhost:3015
API_URL=http://localhost:3016
OPENGITHUB_GIT_STORAGE_DIR=/tmp/opengithub-git-storage
PUBLIC_APP_URL=http://localhost:3015
SESSION_COOKIE_NAME=__Host-session
SESSION_COOKIE_SECURE=false

# Auth -- Google OAuth
# IMPORTANT: You must also configure these in Google Cloud Console:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Add Authorized redirect URI: http://localhost:3016/api/auth/google/callback
#   3. For production, also add: https://your-domain.com/api/auth/google/callback
#   4. Set OAuth consent screen to "External" + Published
#      OR add your test Google account as a test user
#   5. If using Ever CLI for QA: add the Google account your browser
#      is logged into as a test user (Ever uses the existing browser session)
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3015

# Test account — Google account for build/QA agent auth (Ever CLI uses this)
TEST_ACCOUNT_EMAIL=your-google-email@gmail.com

# Dashboard -- simple auth key for the admin dashboard
DASHBOARD_KEY=your-dashboard-key
