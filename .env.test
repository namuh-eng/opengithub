# Local E2E / integration test environment.
# Loaded by `make test-e2e`. Safe to commit — no secrets.
# All values target the docker-compose.test.yml Postgres on :55433.

TEST_DATABASE_URL=postgresql://opengithub:opengithub@localhost:55433/opengithub_test
DATABASE_URL=postgresql://opengithub:opengithub@localhost:55433/opengithub_test
DB_SSL=false

# Session signing — fixed deterministic value so Playwright cookies are
# verifiable across runs. Not a real secret; only valid against the test DB.
SESSION_SECRET=playwright-session-secret-with-enough-entropy-aaaa
SESSION_COOKIE_NAME=og_session
SESSION_COOKIE_SECURE=false

# Google OAuth — stub values; OAuth flow is bypassed in tests via the
# dashboard_e2e_seed fixture which mints session cookies directly.
AUTH_GOOGLE_ID=playwright-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=playwright-client-secret

# App origins — Playwright webServer also exports these.
APP_URL=http://localhost:3015
PUBLIC_APP_URL=http://localhost:3015
NEXT_PUBLIC_APP_URL=http://localhost:3015
API_URL=http://localhost:3016
